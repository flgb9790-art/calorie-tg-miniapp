# Скопируй в .env и заполни. Файл .env в git не коммить.

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=

# Публичный HTTPS (ngrok и т.п.) — корень сайта
WEB_APP_URL=

# Supabase (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Модель для оценки по фото (Vision), по умолчанию gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

APP_TIMEZONE=Europe/Moscow
PORT=3000
